# ── Line Messaging API ─────────────────────────────────────────────────────
# Get from LINE Developers Console → your channel → Messaging API
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# ── Anthropic Claude API ───────────────────────────────────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# Optionally override model (default: claude-opus-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Notion ─────────────────────────────────────────────────────────────────
# Get from https://www.notion.so/profile/integrations → Create integration
NOTION_API_KEY=secret_...

# ID of the Notion page that holds the three PM databases
# (Already created for you — see the 🤖 Line PM Bot Workspace page in Notion)
NOTION_PARENT_PAGE_ID=336b255de5e781a3ac2dc3595665ddf6

# ── Pre-created Notion Database IDs ───────────────────────────────────────
# These databases have already been created in your Notion workspace.
# Copy these values as-is into your .env file.
NOTION_PROJECTS_DB_ID=2941d03dbd3c4ac19f88434f2622a42d
NOTION_TASKS_DB_ID=ce1b0cebe1734ea7a52bf678755107e5
NOTION_UPDATES_DB_ID=0351b964009643cd990b303a0160bbc0

# ── App ────────────────────────────────────────────────────────────────────
PORT=8000
DEBUG=false
